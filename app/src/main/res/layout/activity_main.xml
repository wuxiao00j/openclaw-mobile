<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- 解压进度界面 -->
    <LinearLayout
        android:id="@+id/layoutExtraction"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/extraction_title"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressExtraction"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:progress="0"
            android:progressTint="@color/purple_500" />

        <TextView
            android:id="@+id/tvExtractionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/extraction_message"
            android:textColor="@color/gray_500"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- 主界面 -->
    <LinearLayout
        android:id="@+id/layoutMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 品牌 Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="🤖 OpenClaw"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- 状态显示 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="状态: 初始化中..."
            android:textColor="@color/teal_200"
            android:textSize="16sp" />

        <!-- 按钮组 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenPanel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/open_control_panel"
                android:textSize="16sp"
                app:cornerRadius="28dp"
                app:backgroundTint="@color/purple_500" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewLogs"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/view_logs"
                android:textSize="16sp"
                app:cornerRadius="28dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="@color/white"
                app:strokeColor="@color/purple_500" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRestartService"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/restart_service"
                android:textSize="16sp"
                app:cornerRadius="28dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="@color/white"
                app:strokeColor="@color/purple_500" />

        </LinearLayout>

        <!-- 快捷配置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/api_key_config"
                android:textColor="@color/gray_500"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvApiKeyStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="未配置"
                android:textColor="@color/teal_200"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnEditApiKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/edit"
                android:textColor="@color/purple_500"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
